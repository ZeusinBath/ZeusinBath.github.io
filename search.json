---
layout: null
---
[
  {% raw %}{% for post in site.posts %}{% endraw %}
    {
      "title": "{{ post.title | escape }}",
      "url": "{{ post.url | relative_url }}",
      "content": "{{ post.content | strip_html | normalize_whitespace | truncate: 200 }}"
    }
  {% raw %}{% unless forloop.last %},{% endunless %}{% endfor %}{% endraw %}
]
